      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "histogram_quantile(0.99, sum by (le) (rate(df_checkpoint_duration_seconds_bucket[5m])))",
          "legendFormat": "p99",
          "refId": "A",
          "editorMode": "code",
