    {
      "id": 9,
      "type": "timeseries",
      "title": "Quota system-pauses by reason",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 18,
        "y": 16
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
