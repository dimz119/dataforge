# DataForge dev environment — committed template (deployment-architecture §2.3).
# Copy to infra/compose/.env (gitignored, secrets rule S-1):
#   cp infra/compose/.env.example infra/compose/.env
# Dev values only; never reuse outside dev.

# Environment name; also the API-key env token: df_dev_… (ADR-0011)
DF_ENV=dev

# Settings split per backend-architecture §11
DJANGO_SETTINGS_MODULE=config.settings.dev

# Dev-only constant; never reused outside dev
DJANGO_SECRET_KEY=dataforge-dev-only-insecure-secret-key-do-not-reuse

# Two-role split (backend-architecture §11, §5.4 / SEC-TEN-2). The runtime
# connects as the NOBYPASSRLS `dataforge_app` role so Postgres RLS actually
# constrains it; migrations + role provisioning use the owner via
# MIGRATE_DATABASE_URL. `dataforge_app` is created by infra/compose/initdb on
# first DB init; its grants are (re)applied by `manage.py provision_db_roles`.
DATABASE_URL=postgres://dataforge_app:dataforge_app@postgres:5432/dataforge
MIGRATE_DATABASE_URL=postgres://dataforge:dataforge@postgres:5432/dataforge

# Single logical DB, namespaced keys (deployment-architecture §3.6)
REDIS_URL=redis://redis:6379/0

# The one variable the managed-Kafka swap changes (deployment-architecture §4)
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# Fixed UUID constant (base64url) — prevents KRaft reformat on volume reuse
KAFKA_CLUSTER_ID=3w8Kbn4aTZucPhorPE1ebw

# Captured by the dev-only mailpit service (UI at localhost:8025);
# real provider (Postmark) in staging/prod (deployment-architecture §5)
EMAIL_URL=smtp://mailpit:1025

# Postgres container bootstrap (must agree with DATABASE_URL above)
POSTGRES_USER=dataforge
POSTGRES_PASSWORD=dataforge
POSTGRES_DB=dataforge
