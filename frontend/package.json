{
  "name": "dataforge-console",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "DataForge console — Vite + React + TypeScript SPA (frontend-architecture D11)",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest",
    "format": "prettier --write .",
    "gen:api": "openapi-typescript ../backend/schema/openapi.yaml --enum-values -o src/shared/api/schema.gen.ts && node scripts/gen-api-header.mjs && prettier --write src/shared/api/schema.gen.ts",
    "gen:api:check": "npm run gen:api && git diff --exit-code -- src/shared/api/schema.gen.ts",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test --grep @smoke",
    "test:e2e:nightly": "playwright test --grep @nightly",
    "size:check": "node scripts/check-bundle-size.mjs"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-slider": "^1.2.3",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-toast": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.1.8",
    "@tanstack/react-query": "^5.66.0",
    "@tanstack/react-virtual": "^3.13.0",
    "openapi-fetch": "^0.13.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.54.2",
    "react-router": "^7.1.5",
    "zod": "^3.24.2",
    "@hookform/resolvers": "^3.10.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.1",
    "@playwright/test": "^1.50.1",
    "@eslint/js": "^9.20.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^22.13.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.20.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-import-resolver-typescript": "^3.7.0",
    "eslint-plugin-boundaries": "^5.0.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.14.0",
    "@tailwindcss/vite": "^4.0.6",
    "@testing-library/user-event": "^14.6.1",
    "@vitest/coverage-v8": "^3.0.5",
    "jsdom": "^26.0.0",
    "openapi-typescript": "^7.6.1",
    "prettier": "^3.5.0",
    "tailwindcss": "^4.0.6",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.24.0",
    "vite": "^6.1.0",
    "vitest": "^3.0.5"
  }
}
